RUNTIME=sandbox
ASSISTANT_NAME=Assistant
CLAUDE_CODE_OAUTH_TOKEN=__PASS:claudeclaw/anthropic-oauth-token__
TELEGRAM_BOT_TOKEN=__PASS:claudeclaw/telegram-bot-token__

# Fish Audio (TTS) — used by the built-in voice extension
FISH_AUDIO_API_KEY=__PASS:api/fish-audio-main__

# OpenAI — used by vision captioner for DeepSeek runner (and future tools)
OPENAI_API_KEY=__PASS:lightrag/openai-api-key__

# Exchange On-Premise (optional). Leave blank to disable the exchange MCP tool.
EXCHANGE_SERVER=mail.example.com
EXCHANGE_USERNAME=DOMAIN\\user
EXCHANGE_EMAIL=user@example.com
EXCHANGE_PASSWORD=__PASS:exchange/password__

# Bitrix24 (optional)
BITRIX24_WEBHOOK=__PASS:bitrix24/webhook-token__
BITRIX24_ALLOWED_USER_ID=

# Instagram extension config lives in the instance that owns the IG account.
# This main instance can load the extension code but stays idle when
# INSTAGRAM_* env vars are absent.
